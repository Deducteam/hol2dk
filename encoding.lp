// dk/lp symbols used for encoding simple type theory

builtin "El" ≔ El;
builtin "Prf" ≔ Prf;

// symbols with special notations in Coq
builtin "Set" ≔ Set;
builtin "prop" ≔ bool;
builtin "arr" ≔ fun;
builtin "imp" ≔ ⇒;
builtin "all" ≔ ∀;
builtin "eq" ≔ nothing;
builtin "or" ≔ nothing;
builtin "and" ≔ nothing;
builtin "ex" ≔ nothing;
builtin "not" ≔ nothing;
